class Solution:
    def checkGoodInteger(self, n: int) -> bool:
        ori = n
        digSum = 0
        sqSum = 0
        while n != 0:
            digSum = n%10
            sqSum = ori%10 ** 2
            n = n//10
            ori = ori//10

        if sqSum - digSum >= 50:
            return True

        else:
            return False
        
        
