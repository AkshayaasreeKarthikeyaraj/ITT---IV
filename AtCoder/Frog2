def solve():
    N, K = map(int, input().split())
    h = list(map(int, input().split()))
    dp = [float('inf')] * N

    dp[0] = 0
    for i in range(1, N):
        for j in range(max(0, i - K), i):
            cost = dp[j] + abs(h[i] - h[j])
            if cost < dp[i]:
                dp[i] = cost

    print(dp[N-1])

if __name__ == '__main__':
    solve()
